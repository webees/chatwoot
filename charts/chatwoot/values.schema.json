{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "web": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "size": { "type": "string", "pattern": "^[0-9]+[GMi]+$" }
              }
            }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "architecture": { "type": "string", "enum": ["standalone", "replication"] }
      }
    }
  }
}
